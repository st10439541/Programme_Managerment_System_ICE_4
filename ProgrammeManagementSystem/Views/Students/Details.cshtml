@model ProgrammeManagementSystem.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<h1>Student Details</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h4>Personal Information</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Full Name</dt>
                    <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Phone Number</dt>
                    <dd class="col-sm-8">@(Model.PhoneNumber ?? "Not provided")</dd>

                    <dt class="col-sm-4">Year of Study</dt>
                    <dd class="col-sm-8">Year @Model.YearOfStudy</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4>Registered Modules (@Model.Registrations.Count)</h4>
            </div>
            <div class="card-body">
                @if (Model.Registrations.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Module Code</th>
                                <th>Module Name</th>
                                <th>Credits</th>
                                <th>Registered</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reg in Model.Registrations.OrderBy(r => r.Module?.ModuleCode))
                            {
                                <tr>
                                    <td>@reg.Module?.ModuleCode</td>
                                    <td>@reg.Module?.ModuleName</td>
                                    <td>@reg.Module?.Credits</td>
                                    <td>@reg.DateRegistered.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="alert alert-info">
                        No modules registered yet.
                        <a asp-controller="Registrations" asp-action="Create" asp-route-studentId="@Model.StudentID">Register a module</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.StudentID" class="btn btn-warning">Edit</a>
    <a asp-controller="Registrations" asp-action="Create" asp-route-studentId="@Model.StudentID" class="btn btn-success">Register for Module</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>