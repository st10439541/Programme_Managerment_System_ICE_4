@model ProgrammeManagementSystem.Models.Registration

@{
    ViewData["Title"] = "Register Student for Module";
}

<h2>Register Student for Module</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="StudentID" class="form-label">Student</label>
                <select asp-for="StudentID" class="form-select" asp-items="ViewBag.StudentID">
                    <option value="">-- Select Student --</option>
                </select>
                <span asp-validation-for="StudentID" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ModuleID" class="form-label">Module</label>
                <select asp-for="ModuleID" class="form-select" asp-items="ViewBag.ModuleID">
                    <option value="">-- Select Module --</option>
                </select>
                <span asp-validation-for="ModuleID" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Register</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}