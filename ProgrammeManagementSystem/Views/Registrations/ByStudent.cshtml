@model IEnumerable<ProgrammeManagementSystem.Models.Registration>

@{
    ViewData["Title"] = $"Modules for {ViewBag.StudentName}";
}

<h1>📚 Modules for @ViewBag.StudentName</h1>

<a asp-controller="Students" asp-action="Index" class="btn btn-secondary mb-3">← Back to Students</a>

@if (Model.Any())
{
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Module Code</th>
                <th>Module Name</th>
                <th>Credits</th>
                <th>Academic Year</th>
                <th>Date Registered</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Module?.ModuleCode</td>
                    <td>@item.Module?.ModuleName</td>
                    <td>@item.Module?.Credits</td>
                    <td>@item.Module?.AcademicYear</td>
                    <td>@item.DateRegistered.ToShortDateString()</td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@item.RegistrationID" class="btn btn-sm btn-danger">Unregister</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">This student is not registered for any modules.</div>
}