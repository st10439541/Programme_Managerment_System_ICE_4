@model IEnumerable<ProgrammeManagementSystem.Models.Registration>

@{
    ViewData["Title"] = "Student Registrations";
}

<h1>📝 Student Module Registrations</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Register Student for Module</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Student Name</th>
            <th>Student Email</th>
            <th>Module Name</th>
            <th>Module Code</th>
            <th>Date Registered</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(item.Student?.FirstName) @(item.Student?.LastName)</td>
                <td>@(item.Student?.Email)</td>
                <td>@(item.Module?.ModuleName)</td>
                <td>@(item.Module?.ModuleCode)</td>
                <td>@item.DateRegistered.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.RegistrationID" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.RegistrationID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No student registrations yet. <a asp-action="Create">Register a student for a module.</a>
    </div>
}