@model IEnumerable<ProgrammeManagementSystem.Models.Registration>

@{
    ViewData["Title"] = "Student Registrations";
}

<h1>📝 Student Module Registrations</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Register Student for Module</a>
</p>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>Student</th>
            <th>Module</th>
            <th>Module Code</th>
            <th>Date Registered</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(item.Student?.FirstName) @(item.Student?.LastName)</td>
                <td>@item.Module?.ModuleName</td>
                <td>@item.Module?.ModuleCode</td>
                <td>@item.DateRegistered.ToShortDateString()</td>
                <td>
                    <a asp-action="Delete" asp-route-id="@item.RegistrationID" class="btn btn-sm btn-danger">Unregister</a>
                </td>
            </tr>
        }
    </tbody>
</table>