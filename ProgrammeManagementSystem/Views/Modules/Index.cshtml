@model IEnumerable<ProgrammeManagementSystem.Models.Module>

@{
    ViewData["Title"] = "Modules";
}

<h1>📚 Modules</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Create New Module</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Module Name</th>
            <th>Module Code</th>
            <th>Credits</th>
            <th>Academic Year</th>
            <th>Assigned Lecturer</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ModuleName</td>
                <td>@item.ModuleCode</td>
                <td>@item.Credits</td>
                <td>@item.AcademicYear</td>
                <td>
                    @{
                        var assignment = item.ModuleAssignments?.FirstOrDefault();
                        if (assignment != null && assignment.Lecturer != null)
                        {
                            @($"{assignment.Lecturer.FirstName} {assignment.Lecturer.LastName}")
                        }
                        else
                        {
                            <span class="text-muted">Not assigned</span>
                        }
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ModuleID" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.ModuleID" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ModuleID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No modules found. <a asp-action="Create">Create the first module.</a>
    </div>
}