@model ProgrammeManagementSystem.Models.Module

@{
    ViewData["Title"] = "Module Details";
}

<h1>Module Details</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h4>Module Information</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Module Name</dt>
                    <dd class="col-sm-8">@Model.ModuleName</dd>

                    <dt class="col-sm-4">Module Code</dt>
                    <dd class="col-sm-8">@Model.ModuleCode</dd>

                    <dt class="col-sm-4">Credits</dt>
                    <dd class="col-sm-8">@Model.Credits</dd>

                    <dt class="col-sm-4">Academic Year</dt>
                    <dd class="col-sm-8">@Model.AcademicYear</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-info text-white">
                <h4>Assigned Lecturer</h4>
            </div>
            <div class="card-body">
                @if (Model.ModuleAssignments.Any())
                {
                    var assignment = Model.ModuleAssignments.FirstOrDefault();
                    <dl class="row">
                        <dt class="col-sm-4">Lecturer Name</dt>
                        <dd class="col-sm-8">@(assignment?.Lecturer?.FirstName) @(assignment?.Lecturer?.LastName)</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@(assignment?.Lecturer?.Email)</dd>

                        <dt class="col-sm-4">Department</dt>
                        <dd class="col-sm-8">@(assignment?.Lecturer?.Department)</dd>
                    </dl>
                }
                else
                {
                    <div class="alert alert-warning">
                        No lecturer assigned to this module yet.
                        <a asp-controller="ModuleAssignments" asp-action="Create">Assign a lecturer</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header bg-success text-white">
        <h4>Registered Students (@Model.Registrations.Count)</h4>
    </div>
    <div class="card-body">
        @if (Model.Registrations.Any())
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Student Name</th>
                        <th>Email</th>
                        <th>Year of Study</th>
                        <th>Date Registered</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in Model.Registrations.OrderBy(r => r.Student?.LastName))
                    {
                        <tr>
                            <td>@(reg.Student?.FirstName) @(reg.Student?.LastName)</td>
                            <td>@(reg.Student?.Email)</td>
                            <td>Year @(reg.Student?.YearOfStudy)</td>
                            <td>@reg.DateRegistered.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info">
                No students registered for this module yet.
                <a asp-controller="Registrations" asp-action="Create">Register a student</a>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.ModuleID" class="btn btn-warning">Edit</a>
    <a asp-controller="Registrations" asp-action="Create" class="btn btn-success">Register Student</a>
    <a asp-controller="ModuleAssignments" asp-action="Create" class="btn btn-info">Assign Lecturer</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>