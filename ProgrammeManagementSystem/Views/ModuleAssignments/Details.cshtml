@model ProgrammeManagementSystem.Models.ModuleAssignment

@{
    ViewData["Title"] = "Assignment Details";
}

<h1>Assignment Details</h1>

<div class="card">
    <div class="card-body">
        <h4>Module Assignment Information</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Lecturer Name</dt>
            <dd class="col-sm-9">@(Model.Lecturer?.FirstName) @(Model.Lecturer?.LastName)</dd>

            <dt class="col-sm-3">Lecturer Email</dt>
            <dd class="col-sm-9">@(Model.Lecturer?.Email)</dd>

            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">@(Model.Lecturer?.Department)</dd>

            <dt class="col-sm-3">Module Name</dt>
            <dd class="col-sm-9">@(Model.Module?.ModuleName)</dd>

            <dt class="col-sm-3">Module Code</dt>
            <dd class="col-sm-9">@(Model.Module?.ModuleCode)</dd>

            <dt class="col-sm-3">Credits</dt>
            <dd class="col-sm-9">@(Model.Module?.Credits)</dd>

            <dt class="col-sm-3">Academic Year</dt>
            <dd class="col-sm-9">@(Model.Module?.AcademicYear)</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.AssignmentID" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>