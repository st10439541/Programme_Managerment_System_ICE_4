@model IEnumerable<ProgrammeManagementSystem.Models.ModuleAssignment>

@{
    ViewData["Title"] = "Module Assignments";
}

<h1>📚 Module Assignments (Lecturer to Module)</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Assign Lecturer to Module</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Lecturer</th>
            <th>Department</th>
            <th>Module</th>
            <th>Module Code</th>
            <th>Academic Year</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(item.Lecturer?.FirstName) @(item.Lecturer?.LastName)</td>
                <td>@(item.Lecturer?.Department)</td>
                <td>@(item.Module?.ModuleName)</td>
                <td>@(item.Module?.ModuleCode)</td>
                <td>@(item.Module?.AcademicYear)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.AssignmentID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No module assignments yet. <a asp-action="Create">Assign a lecturer to a module.</a>
    </div>
}